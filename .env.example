# Referencia de variables esperadas por el proyecto.
# No copies estas variables a .env para runtime.
# El proyecto lee TODO desde el entorno del usuario, por ejemplo:
#
#   ./scripts/onboarding.sh
#   source "$HOME/.sistema_gestion_env.sh"
#
# Variables locales (las actuales, para desarrollo local):
# DB_HOST=127.0.0.1
# SGE_LOCAL_DB_ROOT_PWD=cambia_esto_root
# SGE_LOCAL_DB_NAME=sge
# DB_URL_SGE=jdbc:mysql://127.0.0.1:3306/sge
# DB_USER_SGE=admin
# DB_PASSWORD_SGE=cambia_esto

# Variables para Docker (mismo concepto, con sufijo _DOCKER):
# DB_HOST_DOCKER=database
# DB_URL_SGE_DOCKER=jdbc:mysql://database:3306/sge
# RABBITMQ_HOST_DOCKER=rabbitmq
# RABBITMQ_HOST=127.0.0.1
# C4E_HOST_STORAGE_ROOT=$HOME/Downloads/com4energy
# SFTP_HOST=127.0.0.1
# SFTP_PORT=21
# SFTP_USER=user1
# SFTP_PASSWORD=cambia_esto



